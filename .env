# -------------------------------------------------------------------
# Trading profile (recommended control layer)
# Use this to evolve GENESIS from swing -> day by changing only .env.
# You can still override any specific variable below.
# -------------------------------------------------------------------
# TRADING_STYLE=swing
# TRADING_DATA_TIMEFRAME=4h
# TRADING_OHLCV_LIMIT=300
# TRADING_LOOP_INTERVAL_SECONDS=1800

# TRADING_SESSION_ENABLED=false
# TRADING_SESSION_TIMEZONE=America/New_York
# TRADING_SESSION_START=00:00
# TRADING_SESSION_END=23:59
# TRADING_WEEKDAYS_ONLY=false

# TRADING_MAX_TRADES_PER_DAY=6
# TRADING_MAX_DAILY_LOSS_USDT=80
# TRADING_STOP_LOSS_PCT=0.02
# TRADING_TAKE_PROFIT_PCT=0.04

# Quick day-trading profile reference:
TRADING_STYLE=day
TRADING_DATA_TIMEFRAME=5m
TRADING_OHLCV_LIMIT=500
TRADING_LOOP_INTERVAL_SECONDS=300

TRADING_SESSION_ENABLED=false
TRADING_SESSION_TIMEZONE=America/New_York
TRADING_SESSION_START=09:30
TRADING_SESSION_END=16:00
TRADING_WEEKDAYS_ONLY=true

TRADING_MAX_TRADES_PER_DAY=6
TRADING_MAX_DAILY_LOSS_USDT=50
TRADING_STOP_LOSS_PCT=0.008
TRADING_TAKE_PROFIT_PCT=0.015

# -------------------------------------------------------------------
# BingX private API credentials
# Used by private account endpoints and all demo/private trading flows.
# -------------------------------------------------------------------
BINGX_API_KEY='iyi1M2o3N615kkw6cdum1eWFG6EazqjR5xSHeJx8vSnFxIqp6Gx4iAXz4HliH5k4j7q1oBBufnD74iV3XcA'
BINGX_SECRET='cM0fvzkJ5u7dC4BQlE2evEZoRd6toDAnViGEm5ACVlN525CvSvcoF09hQYW6ENSC5jkvBjFWIEM6XNBFEtjew'

# -------------------------------------------------------------------
# Default public market data settings
# Used by market data loading and by the demo loop as the signal source.
# -------------------------------------------------------------------
BINGX_DEFAULT_SYMBOL=BTC/USDT
BINGX_DEFAULT_TIMEFRAME=4h

# -------------------------------------------------------------------
# Demo symbol
# This is the derivatives/demo symbol used for opening and closing demo positions.
# -------------------------------------------------------------------
BINGX_DEMO_SYMBOL=BTC/USDT:USDT

# -------------------------------------------------------------------
# Demo test-order settings
# Used by: scripts/check_bingx_demo_order.py
# Size is defined in USDT notional, not in BTC/ETH amount.
# -------------------------------------------------------------------
BINGX_DEMO_TEST_SIDE=buy
BINGX_DEMO_TEST_USDT=100

# -------------------------------------------------------------------
# Demo open-position settings
# Used by: scripts/open_bingx_demo_position.py
# Opens a real demo position with market order sizing in USDT.
# -------------------------------------------------------------------
BINGX_DEMO_OPEN_SIDE=buy
BINGX_DEMO_OPEN_USDT=100

# -------------------------------------------------------------------
# Demo cycle settings
# Used by: scripts/check_bingx_demo_cycle.py
# Places a demo limit order far from market, verifies it, then cancels it.
# -------------------------------------------------------------------
BINGX_DEMO_CYCLE_SIDE=buy
BINGX_DEMO_CYCLE_USDT=100
BINGX_DEMO_CYCLE_PRICE_OFFSET_PCT=0.2

# -------------------------------------------------------------------
# Demo trading loop settings
# Used by: scripts/run_demo_trading_loop.py
# The loop reads data from the public symbol and trades on the demo symbol.
# -------------------------------------------------------------------
DEMO_LOOP_EXECUTE=false
DEMO_LOOP_DATA_SYMBOL=BTC/USDT
DEMO_LOOP_TRADE_SYMBOL=BTC/USDT:USDT
DEMO_LOOP_TIMEFRAME=4h
DEMO_LOOP_NOTIONAL_USDT=100
DEMO_LOOP_OHLCV_LIMIT=120
DEMO_LOOP_SIGNAL_THRESHOLD=0.15
DEMO_LOOP_JOURNAL_FILE=data/journals/demo_loop_runs.jsonl

# -------------------------------------------------------------------
# Day MTF reversal backtest defaults
# Used by: scripts/run_backtest_day_mtf_reversal.py
# CLI flags override these values when provided.
# -------------------------------------------------------------------
DAY_MTF_SYMBOL=BTC/USDT
DAY_MTF_D1_LIMIT=700
DAY_MTF_H1_LIMIT=3000
DAY_MTF_M5_LIMIT=12000
DAY_MTF_INITIAL_EQUITY_USDT=10000
DAY_MTF_RISK_PER_TRADE=0.01
DAY_MTF_RR=1.2
DAY_MTF_FEE_RATE=0.0005
DAY_MTF_SLIPPAGE_RATE=0.0005
DAY_MTF_MAX_HOLD_BARS=36
DAY_MTF_LOOKBACK_EXTREME=20
DAY_MTF_LOOKBACK_STRUCTURE=12
DAY_MTF_ZONE_TOLERANCE_PCT=0.002
DAY_MTF_OUTPUT_PREFIX=day_mtf_reversal_btc
# Options: strict | relaxed | off | balanced
DAY_MTF_DAILY_BIAS_MODE=strict
# Used only when DAY_MTF_DAILY_BIAS_MODE=balanced
# Options: ret_1 | ret_3
DAY_MTF_BALANCED_RET_COL=ret_1
DAY_MTF_BALANCED_THRESHOLD=0.0
DAY_MTF_ENTRY_WINDOW_BARS=3
DAY_MTF_OUTPUT_PREFIX=day_mtf_reversal_btc
# M5 trigger: ema_cross | ema_or_breakout
DAY_MTF_M5_TRIGGER_MODE=ema_cross
DAY_MTF_M5_BREAKOUT_LOOKBACK=3
# Entry quality filters
DAY_MTF_MIN_RISK_DISTANCE_PCT=0.0015
DAY_MTF_MIN_IMPULSE_PCT=0.003
DAY_MTF_OUTPUT_PREFIX=day_mtf_reversal_btc

# -------------------------------------------------------------------
# Demo scalping daemon settings (overnight runner)
# Used by: scripts/run_demo_scalping_daemon.py
# -------------------------------------------------------------------
SCALP_DAEMON_EXECUTE=true
SCALP_DAEMON_INTERVAL_SECONDS=300
SCALP_DAEMON_MAX_CYCLES=0
SCALP_DAEMON_TIMEFRAME=1m
SCALP_DAEMON_OHLCV_LIMIT=240

# Session config
SCALP_DAEMON_SESSION_ENABLED=false
SCALP_DAEMON_SESSION_TIMEZONE=America/New_York
SCALP_DAEMON_SESSION_START=09:30
SCALP_DAEMON_SESSION_END=16:00
SCALP_DAEMON_WEEKDAYS_ONLY=true

SCALP_DAEMON_OUTSIDE_SESSION_MODE=pause
SCALP_DAEMON_MAX_TRADES_PER_DAY=40
SCALP_DAEMON_MAX_DAILY_LOSS_USDT=50
SCALP_DAEMON_STOP_LOSS_PCT=0.004
SCALP_DAEMON_TAKE_PROFIT_PCT=0.006
SCALP_DAEMON_TIME_STOP_MINUTES=45
SCALP_DAEMON_NOTIONAL_USDT=100
SCALP_DAEMON_LOCK_FILE=data/journals/demo_scalping_daemon.lock
SCALP_DAEMON_HEARTBEAT_FILE=data/journals/demo_scalping_heartbeat.jsonl
SCALP_DAEMON_JOURNAL_FILE=data/journals/demo_scalping_runs.jsonl

# -------------------------------------------------------------------
# Position sizing settings (volatility + conviction + drawdown)
# Used by: scripts/run_demo_trading_loop.py
# -------------------------------------------------------------------
SIZING_TARGET_ANNUAL_VOL=0.6
SIZING_MIN_MULTIPLIER=0.25
SIZING_MAX_MULTIPLIER=1.5
SIZING_MIN_CONVICTION_SCALE=0.25
SIZING_DRAWDOWN_CUTOFF=0.10
SIZING_DRAWDOWN_FLOOR_SCALE=0.35

# -------------------------------------------------------------------
# Ensemble quality filters
# Alphas must pass these thresholds to vote in decision making.
# -------------------------------------------------------------------
ENSEMBLE_MIN_TEST_SHARPE=0
ENSEMBLE_MIN_TEST_PROFIT_FACTOR=1
ENSEMBLE_MAX_TEST_TURNOVER=250

# -------------------------------------------------------------------
# Risk controls for the demo loop
# These limits are applied before the loop opens a new demo position.
# -------------------------------------------------------------------
RISK_MAX_POSITION_USDT=100
RISK_MAX_OPEN_POSITIONS=1

# -------------------------------------------------------------------
# Client behavior
# Shared low-level settings for BingX client initialization.
# -------------------------------------------------------------------
BINGX_ENABLE_RATE_LIMIT=true
BINGX_TIMEOUT_MS=10000
